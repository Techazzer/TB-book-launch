{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/all-exams",
      "destination": "/all-exams.html"
    },
    {
      "source": "/process",
      "destination": "/process.html"
    }
  ]
}
