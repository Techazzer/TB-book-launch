{
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/main.py"
    },
    {
      "source": "/dashboard",
      "destination": "dashboard.html"
    },
    {
      "source": "/all-exams",
      "destination": "all-exams.html"
    },
    {
      "source": "/process",
      "destination": "process.html"
    },
    {
      "source": "/static/(.*)",
      "destination": "/$1"
    }
  ],
  "env": {
    "PYTHONPATH": "."
  }
}
